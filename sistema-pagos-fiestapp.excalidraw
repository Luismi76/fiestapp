    {"type":"text","x":50,"y":305,"width":800,"height":18,"text":"El usuario paga con tarjeta para tener saldo. El IVA se cobra aparte para que el monedero reciba la cantidad exacta.","fontSize":12,"fontFamily":2,"strokeColor":"#868e96","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":11,"version":1,"id":"f1_desc","angle":0,"boundElements":null,"updated":1,"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"El usuario paga con tarjeta para tener saldo. El IVA se cobra aparte para que el monedero reciba la cantidad exacta.","lineHeight":1.25},

