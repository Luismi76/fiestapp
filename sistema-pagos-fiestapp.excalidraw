    {"type":"text","x":365,"y":1123,"width":260,"height":65,"text":"💳 Comisión de Stripe (pasarela de pago)\n\nStripe cobra por cada pago con tarjeta.\n1,5% + 0,25€ por transacción.\nEjemplo: pago de 30€ → Stripe retiene 0,70€\nLo asume el anfitrión (recibe precio - 0,70)","fontSize":10,"fontFamily":2,"strokeColor":"#7048e8","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":95,"version":1,"id":"com2t","angle":0,"boundElements":null,"updated":1,"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"💳 Comisión de Stripe (pasarela de pago)\n\nStripe cobra por cada pago con tarjeta.\n1,5% + 0,25€ por transacción.\nEjemplo: pago de 30€ → Stripe retiene 0,70€\nLo asume el anfitrión (recibe precio - 0,70)","lineHeight":1.25},

