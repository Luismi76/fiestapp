    {"type":"text","x":65,"y":1123,"width":260,"height":65,"text":"🏢 Comisión de la plataforma\n\nSe descuenta del monedero de cada usuario\ncuando la experiencia se completa.\n1,50€ por usuario (total 3€ por experiencia)","fontSize":11,"fontFamily":2,"strokeColor":"#e8590c","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":93,"version":1,"id":"com1t","angle":0,"boundElements":null,"updated":1,"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"🏢 Comisión de la plataforma\n\nSe descuenta del monedero de cada usuario\ncuando la experiencia se completa.\n1,50€ por usuario (total 3€ por experiencia)","lineHeight":1.25},

