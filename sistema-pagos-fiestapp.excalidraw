    {"type":"text","x":665,"y":1123,"width":210,"height":65,"text":"📊 IVA (21%)\n\nSolo se aplica a las recargas\ndel monedero. Se cobra aparte\npara que el saldo sea exacto.\nEj: recarga 4,50€ → paga 5,45€","fontSize":10,"fontFamily":2,"strokeColor":"#2f9e44","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":97,"version":1,"id":"com3t","angle":0,"boundElements":null,"updated":1,"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"📊 IVA (21%)\n\nSolo se aplica a las recargas\ndel monedero. Se cobra aparte\npara que el saldo sea exacto.\nEj: recarga 4,50€ → paga 5,45€","lineHeight":1.25}
