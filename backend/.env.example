# Environment variables for development
NODE_ENV=development

# Database - PostgreSQL (añadir connection_limit y pool_timeout en producción)
# Producción: DATABASE_URL="postgresql://user:pass@host:5432/db?schema=public&connection_limit=10&pool_timeout=30"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fiestapp_dev?schema=public"

# JWT
JWT_SECRET=dev-secret-key-change-in-production-12345
JWT_EXPIRES_IN=7d

# Redsys (TPV CaixaBank) - credenciales de prueba por defecto
REDSYS_MERCHANT_CODE=999008881
REDSYS_TERMINAL=1
REDSYS_SECRET_KEY=sq7HjrUOBfKmC576ILgskD5srU870gJ7
REDSYS_SANDBOX=true
# Tarjeta de prueba: 4548812049400004, caducidad futura, CVV 123

# Stripe (deprecated - ya no se usa)
# STRIPE_SECRET_KEY=sk_test_
# STRIPE_WEBHOOK_SECRET=whsec_

# Cloudinary Storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SendGrid (deprecated)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@fiestapp.com

# Resend (email verification)
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=FiestApp <noreply@lmsc.lmsc.es>

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Backend
PORT=3001

# Seed (set to "true" to run seed on deployment - WARNING: resets all data)
RUN_SEED=false

# Redis (optional, falls back to in-memory cache if not set)
REDIS_URL=redis://localhost:6379

# Sentry (error tracking - optional)
SENTRY_DSN=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# CAPTCHA (hCaptcha - optional)
HCAPTCHA_SECRET_KEY=
